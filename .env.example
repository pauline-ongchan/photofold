# Browser-visible processor base URL.
NEXT_PUBLIC_PROCESSOR_URL=http://127.0.0.1:8000

# Processor configuration for the local Phase 0 prototype.
PHOTOFOLD_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
PHOTOFOLD_DEMO_DATASET=data/demo/hdrplus-static
PHOTOFOLD_WORKSPACE=artifacts/workspace
PHOTOFOLD_RETENTION_HOURS=24

# The deterministic foundation never requires a model provider.
PHOTOFOLD_SEMANTIC_PROVIDER=none

