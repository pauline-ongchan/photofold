{
  "$defs": {
    "AlignmentMeasurement": {
      "additionalProperties": false,
      "properties": {
        "analysis_max_dimension": {
          "exclusiveMinimum": 0,
          "title": "Analysis Max Dimension",
          "type": "integer"
        },
        "description": {
          "minLength": 1,
          "title": "Description",
          "type": "string"
        },
        "max_median_reprojection_error": {
          "exclusiveMinimum": 0,
          "title": "Max Median Reprojection Error",
          "type": "number"
        },
        "min_inlier_ratio": {
          "maximum": 1,
          "minimum": 0,
          "title": "Min Inlier Ratio",
          "type": "number"
        },
        "units": {
          "const": "analysis_pixels",
          "default": "analysis_pixels",
          "title": "Units",
          "type": "string"
        }
      },
      "required": [
        "analysis_max_dimension",
        "max_median_reprojection_error",
        "min_inlier_ratio",
        "description"
      ],
      "title": "AlignmentMeasurement",
      "type": "object"
    },
    "AlignmentRecord": {
      "additionalProperties": false,
      "properties": {
        "decision": {
          "enum": [
            "shared",
            "fallback"
          ],
          "title": "Decision",
          "type": "string"
        },
        "fallback_reason": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Fallback Reason"
        },
        "frame_index": {
          "minimum": 0,
          "title": "Frame Index",
          "type": "integer"
        },
        "inlier_count": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Inlier Count"
        },
        "inlier_ratio": {
          "anyOf": [
            {
              "maximum": 1,
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Inlier Ratio"
        },
        "match_count": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Match Count"
        },
        "median_reprojection_error": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Median Reprojection Error"
        },
        "reference_to_target": {
          "anyOf": [
            {
              "items": {
                "type": "number"
              },
              "maxItems": 9,
              "minItems": 9,
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Reference To Target"
        },
        "reprojection_error_units": {
          "const": "analysis_pixels",
          "default": "analysis_pixels",
          "title": "Reprojection Error Units",
          "type": "string"
        },
        "type": {
          "anyOf": [
            {
              "enum": [
                "identity",
                "affine",
                "homography"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Type"
        },
        "valid_overlap": {
          "anyOf": [
            {
              "maximum": 1,
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Valid Overlap"
        }
      },
      "required": [
        "frame_index",
        "decision",
        "type"
      ],
      "title": "AlignmentRecord",
      "type": "object"
    },
    "Dimensions": {
      "additionalProperties": false,
      "properties": {
        "height": {
          "exclusiveMinimum": 0,
          "title": "Height",
          "type": "integer"
        },
        "width": {
          "exclusiveMinimum": 0,
          "title": "Width",
          "type": "integer"
        }
      },
      "required": [
        "width",
        "height"
      ],
      "title": "Dimensions",
      "type": "object"
    },
    "FrameDisposition": {
      "additionalProperties": false,
      "properties": {
        "fallback_reason": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Fallback Reason"
        },
        "frame_index": {
          "maximum": 19,
          "minimum": 0,
          "title": "Frame Index",
          "type": "integer"
        },
        "storage_mode": {
          "enum": [
            "shared_reference",
            "shared_delta",
            "independent_source"
          ],
          "title": "Storage Mode",
          "type": "string"
        }
      },
      "required": [
        "frame_index",
        "storage_mode"
      ],
      "title": "FrameDisposition",
      "type": "object"
    },
    "ReferenceCandidate": {
      "additionalProperties": false,
      "properties": {
        "alignment_failure_indices": {
          "items": {
            "type": "integer"
          },
          "title": "Alignment Failure Indices",
          "type": "array"
        },
        "alignment_success_count": {
          "minimum": 0,
          "title": "Alignment Success Count",
          "type": "integer"
        },
        "clipped_pixel_fraction": {
          "maximum": 1,
          "minimum": 0,
          "title": "Clipped Pixel Fraction",
          "type": "number"
        },
        "index": {
          "minimum": 0,
          "title": "Index",
          "type": "integer"
        },
        "mean_inlier_ratio": {
          "maximum": 1,
          "minimum": 0,
          "title": "Mean Inlier Ratio",
          "type": "number"
        },
        "mean_valid_overlap": {
          "maximum": 1,
          "minimum": 0,
          "title": "Mean Valid Overlap",
          "type": "number"
        },
        "score": {
          "title": "Score",
          "type": "number"
        },
        "sharpness": {
          "minimum": 0,
          "title": "Sharpness",
          "type": "number"
        },
        "sharpness_score": {
          "maximum": 1,
          "minimum": 0,
          "title": "Sharpness Score",
          "type": "number"
        }
      },
      "required": [
        "index",
        "score",
        "mean_inlier_ratio",
        "mean_valid_overlap",
        "sharpness",
        "sharpness_score",
        "clipped_pixel_fraction",
        "alignment_success_count",
        "alignment_failure_indices"
      ],
      "title": "ReferenceCandidate",
      "type": "object"
    },
    "SourceSnapshot": {
      "additionalProperties": false,
      "properties": {
        "bytes": {
          "exclusiveMinimum": 0,
          "title": "Bytes",
          "type": "integer"
        },
        "decoded_format": {
          "enum": [
            "JPEG",
            "PNG",
            "WEBP"
          ],
          "title": "Decoded Format",
          "type": "string"
        },
        "disposition": {
          "const": "accepted",
          "default": "accepted",
          "title": "Disposition",
          "type": "string"
        },
        "height": {
          "exclusiveMinimum": 0,
          "title": "Height",
          "type": "integer"
        },
        "index": {
          "maximum": 19,
          "minimum": 0,
          "title": "Index",
          "type": "integer"
        },
        "mime_type": {
          "enum": [
            "image/jpeg",
            "image/png",
            "image/webp"
          ],
          "title": "Mime Type",
          "type": "string"
        },
        "mode": {
          "title": "Mode",
          "type": "string"
        },
        "original_artifact": {
          "title": "Original Artifact",
          "type": "string"
        },
        "original_filename": {
          "title": "Original Filename",
          "type": "string"
        },
        "reasons": {
          "items": {
            "type": "string"
          },
          "title": "Reasons",
          "type": "array"
        },
        "sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "title": "Sha256",
          "type": "string"
        },
        "stored_filename": {
          "title": "Stored Filename",
          "type": "string"
        },
        "width": {
          "exclusiveMinimum": 0,
          "title": "Width",
          "type": "integer"
        }
      },
      "required": [
        "index",
        "original_filename",
        "stored_filename",
        "decoded_format",
        "mime_type",
        "mode",
        "bytes",
        "sha256",
        "width",
        "height",
        "original_artifact"
      ],
      "title": "SourceSnapshot",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "alignment": {
      "items": {
        "$ref": "#/$defs/AlignmentRecord"
      },
      "title": "Alignment",
      "type": "array"
    },
    "alignment_measurement": {
      "$ref": "#/$defs/AlignmentMeasurement"
    },
    "analyzed_at": {
      "format": "date-time",
      "title": "Analyzed At",
      "type": "string"
    },
    "config_sha256": {
      "pattern": "^[a-f0-9]{64}$",
      "title": "Config Sha256",
      "type": "string"
    },
    "deferred_fields": {
      "items": {
        "type": "string"
      },
      "title": "Deferred Fields",
      "type": "array"
    },
    "fallback_frame_count": {
      "maximum": 20,
      "minimum": 0,
      "title": "Fallback Frame Count",
      "type": "integer"
    },
    "frame_dispositions": {
      "items": {
        "$ref": "#/$defs/FrameDisposition"
      },
      "maxItems": 20,
      "minItems": 5,
      "title": "Frame Dispositions",
      "type": "array"
    },
    "normalized_dimensions": {
      "anyOf": [
        {
          "$ref": "#/$defs/Dimensions"
        },
        {
          "type": "null"
        }
      ]
    },
    "original_total_bytes": {
      "exclusiveMinimum": 0,
      "title": "Original Total Bytes",
      "type": "integer"
    },
    "reasons": {
      "items": {
        "type": "string"
      },
      "title": "Reasons",
      "type": "array"
    },
    "reference_candidates": {
      "items": {
        "$ref": "#/$defs/ReferenceCandidate"
      },
      "title": "Reference Candidates",
      "type": "array"
    },
    "reference_frame_index": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "title": "Reference Frame Index"
    },
    "reference_score": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "title": "Reference Score"
    },
    "schema_version": {
      "const": "1.1",
      "default": "1.1",
      "title": "Schema Version",
      "type": "string"
    },
    "shared_frame_count": {
      "maximum": 20,
      "minimum": 0,
      "title": "Shared Frame Count",
      "type": "integer"
    },
    "source_frames": {
      "items": {
        "$ref": "#/$defs/SourceSnapshot"
      },
      "maxItems": 20,
      "minItems": 5,
      "title": "Source Frames",
      "type": "array"
    },
    "status": {
      "const": "analyzed_foldable",
      "default": "analyzed_foldable",
      "title": "Status",
      "type": "string"
    },
    "strategy": {
      "enum": [
        "shared_scene",
        "hybrid",
        "independent_only"
      ],
      "title": "Strategy",
      "type": "string"
    },
    "suitability": {
      "enum": [
        "safe_to_fold",
        "foldable_with_reduced_savings"
      ],
      "title": "Suitability",
      "type": "string"
    },
    "warnings": {
      "items": {
        "type": "string"
      },
      "title": "Warnings",
      "type": "array"
    }
  },
  "required": [
    "analyzed_at",
    "suitability",
    "strategy",
    "reasons",
    "source_frames",
    "original_total_bytes",
    "normalized_dimensions",
    "shared_frame_count",
    "fallback_frame_count",
    "frame_dispositions",
    "reference_frame_index",
    "reference_score",
    "reference_candidates",
    "alignment",
    "alignment_measurement",
    "config_sha256",
    "warnings",
    "deferred_fields"
  ],
  "title": "PrototypeAnalysis",
  "type": "object"
}
