{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://photofold.local/schemas/photofold-manifest-0.1.json",
  "title": "PhotoFold Manifest 0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "format",
    "version",
    "created_at",
    "reference_frame_index",
    "required_codecs",
    "base",
    "frames",
    "assets",
    "analysis_path",
    "metrics_path",
    "semantic_analysis_path"
  ],
  "properties": {
    "format": { "const": "photofold" },
    "version": { "const": "0.1" },
    "created_at": { "type": "string", "format": "date-time" },
    "reference_frame_index": { "type": "integer", "minimum": 0 },
    "required_codecs": {
      "type": "array",
      "items": { "enum": ["webp", "png"] },
      "uniqueItems": true
    },
    "base": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "width", "height", "encoding", "quality"],
      "properties": {
        "path": { "const": "base.webp" },
        "width": { "type": "integer", "minimum": 1 },
        "height": { "type": "integer", "minimum": 1 },
        "encoding": { "const": "webp" },
        "quality": { "type": "integer", "minimum": 1, "maximum": 100 }
      }
    },
    "frames": {
      "type": "array",
      "minItems": 5,
      "maxItems": 20,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "index",
          "original_filename",
          "output_width",
          "output_height",
          "transform",
          "patches"
        ],
        "properties": {
          "index": { "type": "integer", "minimum": 0 },
          "original_filename": { "type": "string", "minLength": 1 },
          "output_width": { "type": "integer", "minimum": 1 },
          "output_height": { "type": "integer", "minimum": 1 },
          "transform": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "type",
              "reference_to_target",
              "interpolation",
              "border_mode",
              "inlier_count",
              "inlier_ratio",
              "median_reprojection_error",
              "valid_overlap"
            ],
            "properties": {
              "type": { "enum": ["identity", "affine", "homography"] },
              "reference_to_target": {
                "type": "array",
                "minItems": 9,
                "maxItems": 9,
                "items": { "type": "number" }
              },
              "interpolation": { "const": "linear" },
              "border_mode": { "const": "constant" },
              "inlier_count": { "type": "integer", "minimum": 0 },
              "inlier_ratio": { "type": "number", "minimum": 0, "maximum": 1 },
              "median_reprojection_error": { "type": "number", "minimum": 0 },
              "valid_overlap": { "type": "number", "minimum": 0, "maximum": 1 }
            }
          },
          "patches": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["bbox", "image_path", "mask_path", "feather_radius", "residual_path"],
              "properties": {
                "bbox": {
                  "type": "array",
                  "minItems": 4,
                  "maxItems": 4,
                  "prefixItems": [
                    { "type": "integer", "minimum": 0 },
                    { "type": "integer", "minimum": 0 },
                    { "type": "integer", "minimum": 1 },
                    { "type": "integer", "minimum": 1 }
                  ],
                  "items": false
                },
                "image_path": { "type": "string", "minLength": 1 },
                "mask_path": { "type": "string", "minLength": 1 },
                "feather_radius": { "type": "integer", "minimum": 0, "maximum": 64 },
                "residual_path": { "type": ["string", "null"] }
              }
            }
          }
        }
      }
    },
    "assets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "bytes", "sha256"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "bytes": { "type": "integer", "minimum": 1 },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
        }
      }
    },
    "analysis_path": { "const": "metadata/analysis.json" },
    "metrics_path": { "const": "metadata/metrics.json" },
    "semantic_analysis_path": { "type": "null" }
  }
}
