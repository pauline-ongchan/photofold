{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://photofold.local/schemas/experiment-result-0.1.json",
  "title": "PhotoFold Gate 1 Experiment Result 0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_at",
    "dataset_id",
    "dataset_path",
    "config_path",
    "config_sha256",
    "parameters",
    "reference_frame_index",
    "accepted_frame_count",
    "reconstructed_frame_count",
    "original_total_bytes",
    "package_total_bytes",
    "package_sha256",
    "byte_delta",
    "percent_change",
    "bytes_saved",
    "percent_saved",
    "independent_webp_total_bytes",
    "independent_webp_quality",
    "independent_webp_mean_ssim",
    "independent_webp_minimum_ssim",
    "independent_webp_control_matched",
    "relational_gain_bytes",
    "relational_gain_percent",
    "mean_ssim",
    "minimum_ssim",
    "quality_thresholds",
    "quality_threshold_pass",
    "alignment_threshold_pass",
    "storage_reduction_pass",
    "relational_hypothesis_pass",
    "gate_pass",
    "per_frame",
    "alignment",
    "independent_webp_curve",
    "parameter_sweep",
    "integrity_checks",
    "package_members",
    "failed_checks",
    "limitations",
    "report"
  ],
  "properties": {
    "schema_version": { "const": "0.1" },
    "run_at": { "type": "string", "format": "date-time" },
    "dataset_id": { "type": "string", "minLength": 1 },
    "dataset_path": { "type": "string", "minLength": 1 },
    "config_path": { "type": "string", "minLength": 1 },
    "config_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "parameters": { "type": "object" },
    "reference_frame_index": { "type": "integer", "minimum": 0 },
    "accepted_frame_count": { "type": "integer", "minimum": 5, "maximum": 20 },
    "reconstructed_frame_count": { "type": "integer", "minimum": 5, "maximum": 20 },
    "original_total_bytes": { "type": "integer", "minimum": 1 },
    "package_total_bytes": { "type": "integer", "minimum": 1 },
    "package_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "byte_delta": { "type": "integer" },
    "percent_change": { "type": "number" },
    "bytes_saved": { "type": "integer", "minimum": 0 },
    "percent_saved": { "type": "number", "minimum": 0 },
    "independent_webp_total_bytes": { "type": "integer", "minimum": 1 },
    "independent_webp_quality": { "type": "integer", "minimum": 1, "maximum": 100 },
    "independent_webp_mean_ssim": { "type": "number", "minimum": 0, "maximum": 1 },
    "independent_webp_minimum_ssim": { "type": "number", "minimum": 0, "maximum": 1 },
    "independent_webp_control_matched": { "type": "boolean" },
    "relational_gain_bytes": { "type": "integer" },
    "relational_gain_percent": { "type": "number" },
    "mean_ssim": { "type": "number", "minimum": 0, "maximum": 1 },
    "minimum_ssim": { "type": "number", "minimum": 0, "maximum": 1 },
    "quality_thresholds": {
      "type": "object",
      "additionalProperties": false,
      "required": ["min_per_frame", "min_mean"],
      "properties": {
        "min_per_frame": { "type": "number", "minimum": 0, "maximum": 1 },
        "min_mean": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "quality_threshold_pass": { "type": "boolean" },
    "alignment_threshold_pass": { "type": "boolean" },
    "storage_reduction_pass": { "type": "boolean" },
    "relational_hypothesis_pass": { "type": "boolean" },
    "gate_pass": { "type": "boolean" },
    "per_frame": {
      "type": "array",
      "minItems": 5,
      "maxItems": 20,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "index",
          "filename",
          "width",
          "height",
          "original_bytes",
          "accepted",
          "reconstructed",
          "ssim",
          "quality_threshold_pass",
          "patch_count",
          "changed_region_percent",
          "shared_region_percent",
          "artifacts"
        ],
        "properties": {
          "index": { "type": "integer", "minimum": 0 },
          "filename": { "type": "string", "minLength": 1 },
          "width": { "type": "integer", "minimum": 1 },
          "height": { "type": "integer", "minimum": 1 },
          "original_bytes": { "type": "integer", "minimum": 1 },
          "accepted": { "type": "boolean" },
          "reconstructed": { "type": "boolean" },
          "ssim": { "type": "number", "minimum": 0, "maximum": 1 },
          "quality_threshold_pass": { "type": "boolean" },
          "patch_count": { "type": "integer", "minimum": 0 },
          "changed_region_percent": { "type": "number", "minimum": 0, "maximum": 100 },
          "shared_region_percent": { "type": "number", "minimum": 0, "maximum": 100 },
          "artifacts": { "type": "object" }
        }
      }
    },
    "alignment": { "type": "object" },
    "independent_webp_curve": { "type": "array" },
    "parameter_sweep": { "type": "array" },
    "integrity_checks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label", "pass", "detail"],
        "properties": {
          "id": { "type": "string" },
          "label": { "type": "string" },
          "pass": { "type": "boolean" },
          "detail": { "type": "string" }
        }
      }
    },
    "package_members": { "type": "array" },
    "failed_checks": { "type": "array", "items": { "type": "string" } },
    "limitations": { "type": "array", "items": { "type": "string" } },
    "report": { "type": "object" }
  }
}
